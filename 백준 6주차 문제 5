#pragma warning(disable:4996)
#include <stdio.h>
#include <stdlib.h>

int main() {
	int N, M;
	scanf("%d %d", &N, &M);
	int arr[200] = {0};//모두 0으로 초기화
	for (int i = 0;i < M;i++) {
		int a, b, c;
		scanf("%d %d %d", &a, &b, &c);
		for (int* p = arr + a-1;p < arr + b;p++) {
			*p = c;
		}
	}
	for (int* p = arr;p < arr + N;p++) {
		printf("%d ", *p);
	}
	return 0;
}
