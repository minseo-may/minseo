#include <stdio.h>

int main() {
    int tc;
    scanf("%d", &tc);

    while (tc--) {
        long long T, H, U;
        scanf("%lld %lld %lld", &T, &H, &U);

        long long x = T < U ? T : U;
        long long ans = 4 * x;

        T -= x;
        U -= x;

        if (T > 2 * H)
            ans++;

        ans += 2 * T + 3 * H + 3 * U;

        printf("%lld\n", ans);
    }

    return 0;
}

