#include <stdio.h>

long long gcd(long long a, long long b) {
    while (b) {
        long long t = a % b;
        a = b;
        b = t;
    }
    return a;
}

int main() {
    int t;
    scanf("%d", &t);

    while (t--) {
        long long n, m, a, b;
        scanf("%lld %lld %lld %lld", &n, &m, &a, &b);

        if (gcd(n, a) == 1 &&
            gcd(m, b) == 1 &&
            gcd(n, m) <= 2)
            printf("YES\n");
        else
            printf("NO\n");
    }

    return 0;
}

