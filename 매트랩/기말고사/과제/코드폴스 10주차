2216A	Course Wishes

#include <stdio.h>

int main() {
    int t;
    scanf("%d", &t);

    for (; t > 0; t--) {
        int n, k, a[25], b[55], res[1005], count = 0;
        
        scanf("%d %d", &n, &k);
        for (int i = 1; i <= k; i++) scanf("%d", &a[i]);
        for (int i = 0; i < n; i++) scanf("%d", &b[i]);

        // n * k번 반복하면 모든 과목이 최악의 경우에도 끝까지 도달함
        for (int step = 0; step < n * k; step++) {
            for (int lv = k; lv >= 1; lv--) {
                for (int i = 0; i < n; i++) {
                    if (b[i] == lv) {
                        if (lv + 1 > k) {
                            b[i]++;
                            res[count++] = i + 1;
                        } else {
                            int cnt = 0;
                            for (int j = 0; j < n; j++) {
                                if (b[j] == lv + 1) cnt++;
                            }
                            if (cnt < a[lv + 1]) {
                                b[i]++;
                                res[count++] = i + 1;
                            }
                        }
                    }
                }
            }
        }

        printf("%d\n", count);
        for (int i = 0; i < count; i++) {
            printf("%d%c", res[i], (i == count - 1 ? '\n' : ' '));
        }
        if (count == 0) printf("\n");
    }

    return 0;
}

2210B	Simply Sitting on Chairs


#include <stdio.h>

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;

    for (; t > 0; t--) {
        int n;
        scanf("%d", &n);

        int p[200005];
        for (int i = 1; i <= n; i++) {
            scanf("%d", &p[i]);
        }

        int count = 0;
        for (int i = 1; i <= n; i++) {
            // 나 자신이나 이미 지나온 의자를 마킹하는 경우에만 앉습니다.
            // 이렇게 하면 앞으로 내가 방문할 의자를 절대 마킹하지 않습니다.
            if (p[i] <= i) {
                count++;
            }
        }

        printf("%d\n", count);
    }

    return 0;
}


2217A	The Equalizer

#include <stdio.h>

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;

    while (t--) {
        int n, k;
        if (scanf("%d %d", &n, &k) != 2) break;

        long long total_sum = 0;
        for (int i = 0; i < n; i++) {
            int val;
            scanf("%d", &val);
            total_sum += val;
        }

        long long special_sum = (long long)n * k;

        if (total_sum % 2 != 0 || special_sum % 2 == 0) {
            printf("YES\n");
        } else {
            printf("NO\n");
        }
    }

    return 0;
}

