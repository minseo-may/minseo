#pragma warning(disable:4996)
#include <stdio.h>
#include <stdlib.h>

int main() {
	int ar[42] = { 0 };//배열 모두 0으로 초기화
	for (int i = 0;i < 10;i++) {
		int n;
		scanf("%d", &n);
		ar[n % 42] = 1;//나머지가 나오면 값을 1로 변경
	}
	int c = 0;//나머지 숫자 셀 변수
	for (int i = 0;i <= 41;i++) {
		if (ar[i] == 1) {
			c++;
		}
	}
	printf("%d", c);
	return 0;
}
