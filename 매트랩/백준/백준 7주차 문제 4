#pragma warning(disable:4996)
#include <stdio.h>
#include <stdlib.h>

void reverse(int* ar, int a, int b);

int main() {
	int N, M;
	scanf("%d %d", &N, &M);//입력 받음
	int ar[101];
	for (int i = 0;i < 101;i++) {
		ar[i] = i;//인덱스 번호 부여
	}
	for (int i = 0;i < M;i++) {
		int a, b;
		scanf("%d %d", &a, &b);
		reverse(ar, a, b);
	}
	for (int* p = ar+1;p < ar + N+1;p++) {
		printf("%d ", *p);//최종 바뀐 값 출력
	}
	return 0;
}

void reverse(int* ar, int a, int b) {//뒤집는 함수
	while (a < b) {
		int tmp = ar[a];
		ar[a] = ar[b];
		ar[b] = tmp;
		a++;
		b--;
	}
	return;
}
