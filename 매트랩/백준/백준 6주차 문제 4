#pragma warning(disable:4996)
#include <stdio.h>
#include <stdlib.h>

int main() {
	int arr[9];
	for (int* p = arr;p < arr + 9;p++) {
		scanf("%d", p);//숫자 9개 입력 받음
	}
	int max = arr[0];
	int idx = 1;
	for (int i = 1;i < 9;i++) {
		if (*(arr + i) > max) {
			max = *(arr + i);
			idx = i+1;
		}
	}
	printf("%d\n%d", max, idx);
	return 0;
}
