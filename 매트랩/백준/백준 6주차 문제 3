#pragma warning(disable:4996)
#include <stdio.h>
#include <stdlib.h>

int main() {
	int N;
	scanf("%d", &N);//변수 입력 받음
	int* arr = (int*)malloc(sizeof(int) * N);
	for (int* p = arr;p < arr + N;p++) {
		scanf("%d", p);
	}
	int max = arr[0];
	int min = arr[0];
	for (int* p = arr;p < arr + N;p++) {
		if (*p > max) {
			max = *p;
		}
		if (*p < min) {
			min = *p;
		}
	}
	printf("%d %d", min, max);
	free(arr);
	return 0;
}
