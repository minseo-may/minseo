#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#pragma warning (disable:4996)

int main() {
	int N;
	scanf("%d", &N);
	int num = 1;
	int ar[100][100];
	for (int i = 0;i < N;i++) {
		for (int j = 0;j < N;j++) {
			if (i % 2 == 0) {
				ar[i][j] = num++;
			}
			else {
				ar[i][N - 1 - j] = num++;
			}
		}
	}
	for (int i = 0;i < N;i++) {
		for (int j = 0;j < N;j++) {
			printf(" %d", ar[i][j]);
		}
		printf("\n");
	}
	return 0;
}
